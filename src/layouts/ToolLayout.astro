---
import BaseLayout from './BaseLayout.astro';
import { SITE } from '../data/tools';

interface Props {
  title: string;
  description: string;
  path: string;
  h1: string;
  subtitle?: string;
  faqSchema?: { question: string; answer: string }[];
}

const { title, description, path, h1, subtitle, faqSchema } = Astro.props;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: h1, item: `${SITE.url}${path}` },
  ],
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: `${SITE.url}${path}`,
};

const faqPageSchema = faqSchema?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqSchema.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    }
  : null;

const schema = faqPageSchema
  ? [webPageSchema, breadcrumbSchema, faqPageSchema]
  : [webPageSchema, breadcrumbSchema];
---

<BaseLayout title={title} description={description} path={path} schema={schema}>
  <article class="max-w-site mx-auto px-4 sm:px-6 py-10">
    <header class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-main mb-4">{h1}</h1>
      {subtitle && <p class="text-lg text-muted max-w-3xl">{subtitle}</p>}
    </header>
    <slot />
  </article>
</BaseLayout>
