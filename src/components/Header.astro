---
import { calculators, guides } from '../data/tools';

const navLinks = [
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 bg-surface/95 backdrop-blur border-b border-border">
  <div class="max-w-site mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 group">
        <span
          class="flex h-9 w-9 items-center justify-center rounded-lg bg-primary/10 text-primary font-bold text-sm"
          aria-hidden="true"
        >
          lx
        </span>
        <span class="font-semibold text-main group-hover:text-primary transition-colors">
          WorkspaceLux
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
        <div class="relative group">
          <button
            type="button"
            class="px-3 py-2 text-sm font-medium text-muted hover:text-main rounded-lg hover:bg-slate-50 flex items-center gap-1"
            aria-haspopup="true"
          >
            Calculators
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all"
          >
            <div class="w-72 bg-surface rounded-card border border-border shadow-lg p-2">
              <a
                href="/calculators"
                class="block px-3 py-2 rounded-lg text-sm font-medium text-primary hover:bg-slate-50"
              >
                All Calculators
              </a>
              <div class="border-t border-border my-1"></div>
              {
                calculators.map((tool) => (
                  <a
                    href={tool.href}
                    class="block px-3 py-2 rounded-lg text-sm text-main hover:bg-slate-50 hover:text-primary"
                  >
                    {tool.title}
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <div class="relative group">
          <button
            type="button"
            class="px-3 py-2 text-sm font-medium text-muted hover:text-main rounded-lg hover:bg-slate-50 flex items-center gap-1"
            aria-haspopup="true"
          >
            Guides
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all"
          >
            <div class="w-72 bg-surface rounded-card border border-border shadow-lg p-2">
              <a
                href="/guides"
                class="block px-3 py-2 rounded-lg text-sm font-medium text-primary hover:bg-slate-50"
              >
                All Guides
              </a>
              <div class="border-t border-border my-1"></div>
              {
                guides.map((guide) => (
                  <a
                    href={guide.href}
                    class="block px-3 py-2 rounded-lg text-sm text-main hover:bg-slate-50 hover:text-primary"
                  >
                    {guide.title}
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="px-3 py-2 text-sm font-medium text-muted hover:text-main rounded-lg hover:bg-slate-50"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <button
        type="button"
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-muted hover:text-main hover:bg-slate-50"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="hidden md:hidden border-t border-border bg-surface"
    aria-label="Mobile navigation"
  >
    <div class="max-w-site mx-auto px-4 py-4 space-y-1">
      <a href="/calculators" class="block px-3 py-2 text-sm font-medium text-primary rounded-lg">
        All Calculators
      </a>
      <p class="px-3 py-2 text-xs font-semibold uppercase tracking-wider text-muted">Calculators</p>
      {
        calculators.map((tool) => (
          <a href={tool.href} class="block px-3 py-2 text-sm text-main hover:text-primary rounded-lg">
            {tool.title}
          </a>
        ))
      }
      <a href="/guides" class="block px-3 py-2 mt-4 text-sm font-medium text-primary rounded-lg">
        All Guides
      </a>
      <p class="px-3 py-2 text-xs font-semibold uppercase tracking-wider text-muted">Guides</p>
      {
        guides.map((guide) => (
          <a href={guide.href} class="block px-3 py-2 text-sm text-main hover:text-primary rounded-lg">
            {guide.title}
          </a>
        ))
      }
      <div class="border-t border-border mt-4 pt-4 space-y-1">
        {
          navLinks.map((link) => (
            <a href={link.href} class="block px-3 py-2 text-sm text-main hover:text-primary rounded-lg">
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });
</script>
